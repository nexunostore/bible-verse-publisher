name: Generate Bible Verse

permissions:
  contents: write

on:
  workflow_dispatch:
    inputs:
      reference:
        description: "Bible verse reference (e.g., Acts 1:1)"
        required: true
        type: string

      verse:
        description: "Enter the full verse text exactly as you want it to appear."
        required: true
        type: string

jobs:
  generate:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install jq
        run: sudo apt-get install -y jq

      - name: Extract book, chapter, verse number
        id: parse
        run: |
          REF="${{ github.event.inputs.reference }}"
          REF=$(echo "$REF" | sed 's/^ *//;s/ *$//')

          BOOK=$(echo "$REF" | sed 's/ [0-9].*//')
          CHAPTER=$(echo "$REF" | sed 's/.* \([0-9][0-9]*\):.*/\1/')
          VERSE_NUM=$(echo "$REF" | sed 's/.*:[ ]*\([0-9][0-9]*\).*/\1/')

          echo "book=$BOOK" >> $GITHUB_OUTPUT
          echo "chapter=$CHAPTER" >> $GITHUB_OUTPUT
          echo "verse_num=$VERSE_NUM" >> $GITHUB_OUTPUT

      - name: Use provided verse text (NO OPENAI)
        id: verse_text
        run: |
          echo "text=${{ github.event.inputs.verse }}" >> $GITHUB_OUTPUT

      - name: Load cross references from local JSON
        id: cross
        run: |
          REF="${{ github.event.inputs.reference }}"
          DATA=$(cat data/bible_crossrefs_final.json)
          LIST=$(echo "$DATA" | jq -r --arg ref "$REF" '.[$ref][]')

          echo "ref1=$(echo "$LIST" | sed -n '1p')" >> $GITHUB_OUTPUT
          echo "ref2=$(echo "$LIST" | sed -n '2p')" >> $GITHUB_OUTPUT
          echo "ref3=$(echo "$LIST" | sed -n '3p')" >> $GITHUB_OUTPUT
          echo "ref4=$(echo "$LIST" | sed -n '4p')" >> $GITHUB_OUTPUT

      - name: Parse cross-reference components
        id: split
        run: |
          parse_ref() {
            BOOK=$(echo "$1" | sed 's/ [0-9].*//')
            CHAPTER=$(echo "$1" | sed 's/.* \([0-9][0-9]*\):.*/\1/')
            VERSE=$(echo "$1" | sed 's/.*:[ ]*\([0-9][0-9]*\).*/\1/')
            echo "$BOOK|$CHAPTER|$VERSE"
          }

          echo "p1=$(parse_ref '${{ steps.cross.outputs.ref1 }}')" >> $GITHUB_OUTPUT
          echo "p2=$(parse_ref '${{ steps.cross.outputs.ref2 }}')" >> $GITHUB_OUTPUT
          echo "p3=$(parse_ref '${{ steps.cross.outputs.ref3 }}')" >> $GITHUB_OUTPUT
          echo "p4=$(parse_ref '${{ steps.cross.outputs.ref4 }}')" >> $GITHUB_OUTPUT

      - name: Generate meaning using OpenAI
        id: meaning
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
        run: |
          sanitize_yaml() {
            echo "$1" \
              | sed 's/"/\\"/g' \
              | sed "s/’/'/g" \
              | sed "s/‘/'/g" \
              | sed 's/“/"/g' \
              | sed 's/”/"/g' \
              | sed 's/^:/- /' \
              | sed 's/^"/- "/' \
              | tr '\n' ' '
          }

          REF="${{ github.event.inputs.reference }}"

          RESPONSE=$(curl -s https://api.openai.com/v1/chat/completions \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer $OPENAI_API_KEY" \
            -d "{
              \"model\": \"gpt-4o-mini\",
              \"messages\": [{
                \"role\": \"user\",
                \"content\": \"Provide a doctrinally sound explanation of the meaning of $REF in 3-5 sentences.\"
              }]
            }")

          RAW=$(echo "$RESPONSE" | jq -r '.choices[0].message.content')
          SAFE=$(sanitize_yaml "$RAW")
          echo "meaning=$SAFE" >> $GITHUB_OUTPUT

      - name: Generate notes for cross references
        id: notes
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
        run: |
          sanitize_yaml() {
            echo "$1" \
              | sed 's/"/\\"/g' \
              | sed "s/’/'/g" \
              | sed "s/‘/'/g" \
              | sed 's/“/"/g' \
              | sed 's/”/"/g' \
              | sed 's/^:/- /' \
              | sed 's/^"/- "/' \
              | tr '\n' ' '
          }

          gen_note() {
            RESPONSE=$(curl -s https://api.openai.com/v1/chat/completions \
              -H "Content-Type: application/json" \
              -H "Authorization: Bearer $OPENAI_API_KEY" \
              -d "{
                \"model\": \"gpt-4o-mini\",
                \"messages\": [{
                  \"role\": \"user\",
                  \"content\": \"Provide a one-sentence theological note explaining why this verse is a cross-reference: $1\"
                }]
              }")

            RAW=$(echo "$RESPONSE" | jq -r '.choices[0].message.content')
            sanitize_yaml "$RAW"
          }

          echo "n1=$(gen_note '${{ steps.cross.outputs.ref1 }}')" >> $GITHUB_OUTPUT
          echo "n2=$(gen_note '${{ steps.cross.outputs.ref2 }}')" >> $GITHUB_OUTPUT
          echo "n3=$(gen_note '${{ steps.cross.outputs.ref3 }}')" >> $GITHUB_OUTPUT
          echo "n4=$(gen_note '${{ steps.cross.outputs.ref4 }}')" >> $GITHUB_OUTPUT

      - name: Write YAML output (fully safe heredoc)
        run: |
          sanitize_yaml() {
            echo "$1" \
              | sed 's/"/\\"/g' \
              | sed "s/’/'/g" \
              | sed "s/‘/'/g" \
              | sed 's/“/"/g' \
              | sed 's/”/"/g' \
              | sed 's/^:/- /' \
              | sed 's/^"/- "/' \
              | tr '\n' ' '
          }

          BOOK="${{ steps.parse.outputs.book }}"
          CHAPTER="${{ steps.parse.outputs.chapter }}"
          VERSE_NUM="${{ steps.parse.outputs.verse_num }}"
          LBOOK=$(echo "$BOOK" | tr '[:upper:]' '[:lower:]')
          DATE=$(date +%Y-%m-%d)
          FILE="verses/$DATE-$LBOOK-$CHAPTER-$VERSE_NUM.yaml"

          mkdir -p verses

          # Canonical book order
          declare -A ORDER=(
            ["Genesis"]=1 ["Exodus"]=2 ["Leviticus"]=3 ["Numbers"]=4 ["Deuteronomy"]=5
            ["Joshua"]=6 ["Judges"]=7 ["Ruth"]=8 ["1 Samuel"]=9 ["2 Samuel"]=10
            ["1 Kings"]=11 ["2 Kings"]=12 ["1 Chronicles"]=13 ["2 Chronicles"]=14
            ["Ezra"]=15 ["Nehemiah"]=16 ["Esther"]=17
            ["Job"]=18 ["Psalms"]=19 ["Proverbs"]=20 ["Ecclesiastes"]=21 ["Song of Solomon"]=22
            ["Isaiah"]=23 ["Jeremiah"]=24 ["Lamentations"]=25 ["Ezekiel"]=26 ["Daniel"]=27
            ["Hosea"]=28 ["Joel"]=29 ["Amos"]=30 ["Obadiah"]=31 ["Jonah"]=32
            ["Micah"]=33 ["Nahum"]=34 ["Habakkuk"]=35 ["Zephaniah"]=36
            ["Haggai"]=37 ["Zechariah"]=38 ["Malachi"]=39
            ["Matthew"]=40 ["Mark"]=41 ["Luke"]=42 ["John"]=43
            ["Acts"]=44
            ["Romans"]=45 ["1 Corinthians"]=46 ["2 Corinthians"]=47 ["Galatians"]=48
            ["Ephesians"]=49 ["Philippians"]=50 ["Colossians"]=51
            ["1 Thessalonians"]=52 ["2 Thessalonians"]=53 ["1 Timothy"]=54
            ["2 Timothy"]=55 ["Titus"]=56 ["Philemon"]=57
            ["Hebrews"]=58 ["James"]=59 ["1 Peter"]=60 ["2 Peter"]=61
            ["1 John"]=62 ["2 John"]=63 ["3 John"]=64 ["Jude"]=65
            ["Revelation"]=66
          )

          # Book group mapping
          declare -A GROUPMAP=(
            ["Genesis"]="torah" ["Exodus"]="torah" ["Leviticus"]="torah" ["Numbers"]="torah" ["Deuteronomy"]="torah"
            ["Joshua"]="historical-books" ["Judges"]="historical-books" ["Ruth"]="historical-books"
            ["1 Samuel"]="historical-books" ["2 Samuel"]="historical-books"
            ["1 Kings"]="historical-books" ["2 Kings"]="historical-books"
            ["1 Chronicles"]="historical-books" ["2 Chronicles"]="historical-books"
            ["Ezra"]="historical-books" ["Nehemiah"]="historical-books" ["Esther"]="historical-books"
            ["Job"]="wisdom-books" ["Psalms"]="wisdom-books" ["Proverbs"]="wisdom-books"
            ["Ecclesiastes"]="wisdom-books" ["Song of Solomon"]="wisdom-books"
            ["Isaiah"]="major-prophets" ["Jeremiah"]="major-prophets" ["Lamentations"]="major-prophets"
            ["Ezekiel"]="major-prophets" ["Daniel"]="major-prophets"
            ["Hosea"]="minor-prophets" ["Joel"]="minor-prophets" ["Amos"]="minor-prophets"
            ["Obadiah"]="minor-prophets" ["Jonah"]="minor-prophets" ["Micah"]="minor-prophets"
            ["Nahum"]="minor-prophets" ["Habakkuk"]="minor-prophets" ["Zephaniah"]="minor-prophets"
            ["Haggai"]="minor-prophets" ["Zechariah"]="minor-prophets" ["Malachi"]="minor-prophets"
            ["Matthew"]="gospels" ["Mark"]="gospels" ["Luke"]="gospels" ["John"]="gospels"
            ["Acts"]="acts"
            ["Romans"]="pauline-epistles" ["1 Corinthians"]="pauline-epistles" ["2 Corinthians"]="pauline-epistles"
            ["Galatians"]="pauline-epistles" ["Ephesians"]="pauline-epistles" ["Philippians"]="pauline-epistles"
            ["Colossians"]="pauline-epistles" ["1 Thessalonians"]="pauline-epistles" ["2 Thessalonians"]="pauline-epistles"
            ["1 Timothy"]="pauline-epistles" ["2 Timothy"]="pauline-epistles" ["Titus"]="pauline-epistles"
            ["Philemon"]="pauline-epistles"
            ["Hebrews"]="general-epistles" ["James"]="general-epistles" ["1 Peter"]="general-epistles"
            ["2 Peter"]="general-epistles" ["1 John"]="general-epistles" ["2 John"]="general-epistles"
            ["3 John"]="general-epistles" ["Jude"]="general-epistles"
            ["Revelation"]="revelation"
          )

          GROUP=${GROUPMAP[$BOOK]}
          BOOK_ORDER=${ORDER[$BOOK]}

          IFS='|' read B1 C1 V1 <<< "${{ steps.split.outputs.p1 }}"
          IFS='|' read B2 C2 V2 <<< "${{ steps.split.outputs.p2 }}"
          IFS='|' read B3 C3 V3 <<< "${{ steps.split.outputs.p3 }}"
          IFS='|' read B4 C4 V4 <<< "${{ steps.split.outputs.p4 }}"

          SAFE_MEANING=$(sanitize_yaml "${{ steps.meaning.outputs.meaning }}")
          N1=$(sanitize_yaml "${{ steps.notes.outputs.n1 }}")
          N2=$(sanitize_yaml "${{ steps.notes.outputs.n2 }}")
          N3=$(sanitize_yaml "${{ steps.notes.outputs.n3 }}")
          N4=$(sanitize_yaml "${{ steps.notes.outputs.n4 }}")

          cat > "$FILE" <<EOF
          book: $BOOK
          book_order: $BOOK_ORDER
          group: $GROUP
          reference: "${{ github.event.inputs.reference }}"
          verse: >
            ${{ steps.verse_text.outputs.text }}
          meaning: >
            $SAFE_MEANING
          cross_refs:
            - book: $B1
              chapter: $C1
              verse: $V1
              note: "$N1"
            - book: $B2
              chapter: $C2
              verse: $V2
              note: "$N2"
            - book: $B3
              chapter: $C3
              verse: $V3
              note: "$N3"
            - book: $B4
              chapter: $C4
              verse: $V4
              note: "$N4"
          EOF

      - name: Commit verse file
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@github.com"
          git add verses
          git commit -m "Generated verse ${{ github.event.inputs.reference }}" || echo "No changes"
          git push
